{
    "name": "celaraze/cat",
    "type": "project",
    "description": "一个开源的、开放的一站式 IT 运维管理平台。资产管理、工单、盘点以及可靠的移动端应用支持。",
    "keywords": [
        "laravel",
        "cat",
        "chemex",
        "asset",
        "it"
    ],
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.4",
        "awcodes/shout": "^4.0",
        "bezhansalleh/filament-shield": "^4.2",
        "filament/actions": "^5.0",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/infolists": "^5.0",
        "filament/notifications": "^5.0",
        "filament/tables": "^5.0",
        "filament/widgets": "^5.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.12",
        "laravel/sanctum": "^4.2",
        "leandrocfe/filament-apex-charts": "^5.0",
        "psr/simple-cache": "^3.0",
        "pxlrbt/filament-excel": "^3.6",
        "solution-forest/filament-tree": "^4.0",
        "swisnl/filament-backgrounds": "^2.0",
        "tymon/jwt-auth": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.26",
        "laravel/sail": "^1.43",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "orangehill/iseed": "*",
        "phpunit/phpunit": "^13.0",
        "spatie/laravel-ignition": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "process-timeout": 1200
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
